{
    "name": "codeinwp/woocommerce-product-addon",
    "description": "PPOM for WooCommerce",
    "type": "project",
    "license": "GPL-2.0+",
    "authors": [
        {
            "name": "Themeisle",
            "email": "friends@themeisle.com",
            "homepage": "https://themeisle.com"
        }
    ],
    "scripts": {
        "lint": "phpcs --standard=phpcs.xml",
        "lint:generate:baseline": "php vendor/bin/phpcs '--report=\\DR\\CodeSnifferBaseline\\Reports\\Baseline' --report-file=phpcs.baseline.xml --basepath=.",
        "format": "phpcbf --standard=phpcs.xml",
        "phpstan": "phpstan --memory-limit=-1",
        "phpstan:generate:baseline": "phpstan --generate-baseline --memory-limit=-1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "platform-check": false,
        "platform": {
            "php": "7.4"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "digitalrevolution/php-codesniffer-baseline": true
        }
    },
    "extra": {
        "installer-disable": "true"
    },
    "require": {
        "codeinwp/themeisle-sdk": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "PPOM\\": "src/"
        },
        "files": [
            "vendor/codeinwp/themeisle-sdk/load.php"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "yoast/phpunit-polyfills": "^2.0",
        "phpstan/phpstan": "^2",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/woocommerce-stubs": "^10.6",
        "damian-elenbaas/elementor-stubs": "^3.31",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^3.0@dev",
        "automattic/vipwpcs": "^3.0",
        "digitalrevolution/php-codesniffer-baseline": "^1.1"
    }
}
